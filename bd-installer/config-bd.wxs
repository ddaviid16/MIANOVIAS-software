<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Product Id="*"
           Name="MIANOVIAS - Configuracion Base de Datos"
           Version="1.0.0.0"
           Manufacturer="Local Deploy"
           Language="1033"
           Codepage="1252"
           UpgradeCode="{CF8A1D3E-4B92-4F7A-BC2E-A9D3C0E17F52}">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine"/>
    <MajorUpgrade DowngradeErrorMessage="Ya hay una version mas reciente instalada."/>
    <MediaTemplate EmbedCab="yes"/>

    <!-- ── Directorios ─────────────────────────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MIANOVIAS BD Config">

          <!-- Carpeta vacía de marcador (necesaria para WiX) -->
          <Component Id="CompPlaceholder" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">
            <CreateFolder/>
          </Component>

          <!-- Script que carga el schema -->
          <Component Id="CompLoadSchema" Guid="{B2C3D4E5-F601-7890-BCDE-F01234567891}">
            <File Id="FileLoadSchema"
                  Source="load-schema.ps1"
                  KeyPath="yes"/>
          </Component>

          <!-- Archivo SQL con el schema inicial -->
          <Component Id="CompSchemaSql" Guid="{C3D4E5F6-0712-7890-CDEF-012345678902}">
            <File Id="FileSchemaSql"
                  Source="..\sql\schema-tienda_vestidos.sql"
                  KeyPath="yes"/>
          </Component>

        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Level="1">
      <ComponentRef Id="CompPlaceholder"/>
      <ComponentRef Id="CompLoadSchema"/>
      <ComponentRef Id="CompSchemaSql"/>
    </Feature>

    <!-- ── Custom Actions ─────────────────────────────────────────────────── -->

    <!-- CA 1: Configurar contrasena de root en MySQL fresco. -->
    <CustomAction Id="SetMySQLPwdCmd"
                  Execute="immediate"
                  Property="RunMySQLPwd"
                  Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -EncodedCommand $(var.MySQLPwdB64)"/>

    <CustomAction Id="RunMySQLPwd"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore"/>

    <!-- CA 2: Cargar el schema inicial de la base de datos.
         Los archivos load-schema.ps1 y schema-tienda_vestidos.sql
         ya estan en disco (los instalo InstallFiles antes). -->
    <CustomAction Id="SetLoadSchemaCmd"
                  Execute="immediate"
                  Property="RunLoadSchema"
                  Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]load-schema.ps1&quot; &quot;[INSTALLFOLDER]schema-tienda_vestidos.sql&quot;"/>

    <CustomAction Id="RunLoadSchema"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore"/>

    <!-- CA 3: Registrar conexion MIANOVIAS en Workbench. -->
    <CustomAction Id="SetWorkbenchCmd"
                  Execute="immediate"
                  Property="RunWorkbench"
                  Value="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -EncodedCommand $(var.WorkbenchB64)"/>

    <CustomAction Id="RunWorkbench"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore"/>

    <InstallExecuteSequence>
      <!-- 1) Configurar contrasena de root -->
      <Custom Action="SetMySQLPwdCmd"   Before="RunMySQLPwd">NOT Installed</Custom>
      <Custom Action="RunMySQLPwd"      After="InstallFiles">NOT Installed</Custom>
      <!-- 2) Cargar schema (despues de tener contrasena; archivos ya en disco) -->
      <Custom Action="SetLoadSchemaCmd" Before="RunLoadSchema">NOT Installed</Custom>
      <Custom Action="RunLoadSchema"    After="RunMySQLPwd">NOT Installed</Custom>
      <!-- 3) Registrar conexion Workbench -->
      <Custom Action="SetWorkbenchCmd"  Before="RunWorkbench">NOT Installed</Custom>
      <Custom Action="RunWorkbench"     After="RunLoadSchema">NOT Installed</Custom>
    </InstallExecuteSequence>

  </Product>
</Wix>
