<?xml version="1.0" encoding="UTF-8"?>
<!--
  Bundle.wxs — Burn bootstrapper que encadena:
    1. MySQL 8.0.43 Server (solo si no hay MySQL instalado)
    2. config-bd.msi     (siempre: configura password + conexion Workbench)

  Genera: setup-bd.exe
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:bal="http://schemas.microsoft.com/wix/BalExtension"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Bundle Name="MIANOVIAS - Instalacion Base de Datos"
          Version="1.0.0.0"
          Manufacturer="Local Deploy"
          UpgradeCode="{3F8B2C1A-9D47-4E6B-A5F3-C8E20B914D73}">

    <BootstrapperApplicationRef Id="WixStandardBootstrapperApplication.HyperlinkLicense">
      <bal:WixStandardBootstrapperApplication
          LicenseUrl=""
          SuppressOptionsUI="yes"
          SuppressRepair="yes"/>
    </BootstrapperApplicationRef>

    <!-- ── Deteccion de MySQL instalado ──────────────────────────────────────
         Se consulta el SCM (Service Control Manager) en lugar de las claves
         de aplicacion SOFTWARE\MySQL AB, porque esas claves pueden quedar como
         residuo tras una desinstalacion y provocar que el instalador salte MySQL
         aunque no haya ningun servicio activo.
         Si no existe ningun servicio MySQL en el SCM, la variable queda vacia
         y la condicion es verdadera → se instala MySQL.
    -->
    <util:RegistrySearch Id="SearchMySQLSvc"
        Root="HKLM"
        Key="SYSTEM\CurrentControlSet\Services\MySQL"
        Value="ImagePath"
        Variable="MySQLSvcPath"
        Result="value"
        Win64="no"/>

    <util:RegistrySearch Id="SearchMySQL80Svc"
        Root="HKLM"
        Key="SYSTEM\CurrentControlSet\Services\MySQL80"
        Value="ImagePath"
        Variable="MySQL80SvcPath"
        Result="value"
        Win64="no"/>

    <util:RegistrySearch Id="SearchMySQL84Svc"
        Root="HKLM"
        Key="SYSTEM\CurrentControlSet\Services\MySQL84"
        Value="ImagePath"
        Variable="MySQL84SvcPath"
        Result="value"
        Win64="no"/>

    <util:RegistrySearch Id="SearchMySQL57Svc"
        Root="HKLM"
        Key="SYSTEM\CurrentControlSet\Services\MySQL57"
        Value="ImagePath"
        Variable="MySQL57SvcPath"
        Result="value"
        Win64="no"/>

    <Chain>

      <!-- MySQL 8.0.43: se instala SOLO si no existe ningun servicio MySQL en el SCM.
           Usar el SCM es mas fiable que las claves de aplicacion, que pueden
           quedar como residuo tras una desinstalacion. -->
      <MsiPackage Id="MySQLServer"
                  Name="MySQL Server 8.0.43"
                  SourceFile="mysql-8.0.43-winx64.msi"
                  DisplayInternalUI="no"
                  ForcePerMachine="yes"
                  Vital="yes"
                  InstallCondition="MySQLSvcPath = &quot;&quot; AND MySQL80SvcPath = &quot;&quot; AND MySQL84SvcPath = &quot;&quot; AND MySQL57SvcPath = &quot;&quot;">
        <!-- Instala el servicio con nombre MySQL, inicio automatico y lo arranca -->
        <MsiProperty Name="ALLUSERS"        Value="1"/>
        <MsiProperty Name="SERVICENAME"     Value="MySQL"/>
        <MsiProperty Name="MYSQL_AUTOSTART" Value="1"/>
      </MsiPackage>

      <!-- Configuracion (siempre se ejecuta): password + Workbench -->
      <MsiPackage Id="ConfigBD"
                  Name="Configuracion MIANOVIAS"
                  SourceFile="config-bd.msi"
                  DisplayInternalUI="no"
                  ForcePerMachine="yes"
                  Vital="yes"/>

    </Chain>
  </Bundle>
</Wix>
